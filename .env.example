# ── Base de datos ──
DATABASE_URL="postgresql://wikigdd:CHANGEME@localhost:5432/wikigdd?schema=public"
POSTGRES_USER="wikigdd"
POSTGRES_PASSWORD="CHANGEME"
POSTGRES_DB="wikigdd"

# ── Backend ──
NODE_ENV="development"
PORT="3000"
JWT_SECRET="CHANGEME_genera_uno_largo_aleatorio_minimo_32_chars"
SESSION_COOKIE_NAME="session"
SESSION_TTL_DAYS="30"

# ── Admin inicial (seed) ──
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGEME_password_seguro"
ADMIN_DISPLAY_NAME="Admin"

# ── Media ──
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="10"

# ── Frontend / dominio ──
DOMAIN="wiki.tudominio.com"
VITE_API_BASE="/wiki"

# ── CORS (dev) ──
CORS_ORIGIN="http://localhost:5173"

# ── Demo seed opcional ──
SEED_DEMO="false"
